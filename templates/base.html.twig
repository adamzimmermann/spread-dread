<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}March Madness{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-blue-800 text-white px-4 py-3 flex items-center justify-between">
        <a href="{{ path('app_bracket_index') }}" class="text-lg font-bold">March Madness</a>
        {% if app.session.get('user_id') %}
            <span class="text-sm text-blue-200 mr-3">{{ app.session.get('username') }}</span>
            <a href="{{ path('app_logout') }}" class="text-sm text-blue-200 hover:text-white">Logout</a>
        {% endif %}
    </nav>

    {% for type in ['success', 'error', 'info'] %}
        {% for message in app.flashes(type) %}
            <div class="px-4 py-2 text-sm {{ type == 'error' ? 'bg-red-100 text-red-800' : (type == 'success' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800') }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <main class="max-w-lg mx-auto px-4 py-4">
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</body>
</html>
