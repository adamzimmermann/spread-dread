{% extends 'base.html.twig' %}

{% block title %}{{ bracket.name }} - March Madness{% endblock %}

{% block body %}
<div class="mb-3 flex items-start justify-between">
    <div>
        <h1 class="text-xl font-bold text-gray-800">{{ bracket.name }}</h1>
        <p class="text-sm text-gray-500">{{ bracket.year }}</p>
    </div>
    <a href="{{ path('app_bracket_edit', {id: bracket.id}) }}"
       class="text-sm text-blue-600 hover:underline mt-1">Edit</a>
</div>

{# Sticky score card #}
<div class="sticky top-0 z-10 bg-blue-700 text-white rounded-lg px-4 py-3 mb-4 shadow-lg" id="score-card">
    <div class="flex items-center justify-between">
        <div class="text-center flex-1">
            <div class="text-xs uppercase tracking-wide opacity-80 flex items-center justify-center gap-1">
                <span class="w-2 h-2 rounded-full {{ current_player == 1 ? 'bg-blue-300' : 'bg-red-400' }} inline-block"></span>
                {{ scores.player1_name }}
            </div>
            <div class="text-2xl font-bold" id="score-p1">{{ scores.player1 }}</div>
        </div>
        <div class="text-lg font-light opacity-60 px-2">vs</div>
        <div class="text-center flex-1">
            <div class="text-xs uppercase tracking-wide opacity-80 flex items-center justify-center gap-1">
                <span class="w-2 h-2 rounded-full {{ current_player == 2 ? 'bg-blue-300' : 'bg-red-400' }} inline-block"></span>
                {{ scores.player2_name }}
            </div>
            <div class="text-2xl font-bold" id="score-p2">{{ scores.player2 }}</div>
        </div>
    </div>
</div>

{# Round tabs #}
<div class="flex gap-2 overflow-x-auto pb-2 mb-3 -mx-1 px-1" id="round-tabs">
    {% for roundNum, roundName in availableRounds %}
        <a href="{{ path('app_bracket_show', {id: bracket.id, round: roundNum}) }}"
           class="whitespace-nowrap px-3 py-1.5 rounded-full text-sm font-medium transition-colors
                  {{ currentRound == roundNum ? 'bg-blue-700 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' }}">
            {{ roundName }}
        </a>
    {% endfor %}
</div>

{# Action buttons #}
<div class="flex gap-2 mb-4">
    <button onclick="pullSpreads({{ bracket.id }}, {{ currentRound }})"
            class="flex-1 bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded text-sm font-medium hover:bg-gray-50 cursor-pointer"
            id="btn-spreads"
            data-has-spreads="{{ roundHasSpreads ? '1' : '0' }}"
            data-has-picks="{{ roundHasPicks ? '1' : '0' }}">
        Pull Spreads
    </button>
    <button onclick="updateScores({{ bracket.id }}, {{ currentRound }})"
            class="flex-1 bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded text-sm font-medium hover:bg-gray-50 cursor-pointer"
            id="btn-scores">
        Update Scores
    </button>
</div>

{# Pick progress indicator #}
{% if myPickTotal > 0 %}
<div class="flex gap-2 mb-4" id="pick-progress">
    <div class="flex-1 bg-white rounded-lg border border-gray-200 p-2.5" id="pick-progress-my">
        <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-blue-700">My picks</span>
            <span class="text-xs text-gray-500" id="pick-progress-my-text">{{ myPicksDone }}/{{ myPickTotal }}</span>
        </div>
        <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all {{ myPicksDone == myPickTotal ? 'bg-green-500' : 'bg-blue-500' }}"
                 id="pick-progress-my-bar"
                 style="width: {{ myPickTotal > 0 ? (myPicksDone / myPickTotal * 100) : 0 }}%"></div>
        </div>
    </div>
    <div class="flex-1 bg-white rounded-lg border border-gray-200 p-2.5" id="pick-progress-opponent">
        <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-red-600">{{ opponentName }}'s picks</span>
            <span class="text-xs text-gray-500" id="pick-progress-opponent-text">{{ opponentPicksDone }}/{{ opponentPickTotal }}</span>
        </div>
        <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all {{ opponentPicksDone == opponentPickTotal ? 'bg-green-500' : 'bg-red-400' }}"
                 id="pick-progress-opponent-bar"
                 style="width: {{ opponentPickTotal > 0 ? (opponentPicksDone / opponentPickTotal * 100) : 0 }}%"></div>
        </div>
    </div>
</div>
{% endif %}

{% set showRegionTabs = currentRound <= 3 %}

{# Sticky region tabs — rounds 1-3 only #}
{% if showRegionTabs %}
    <div class="sticky z-[9] bg-gray-100 -mx-4 px-4 py-2 border-b border-gray-200" id="region-tabs" style="top: 0px">
        <div class="flex gap-2">
            {% for region in ['East', 'West', 'South', 'Midwest'] %}
                <button onclick="scrollToRegion('{{ region }}')"
                        class="flex-1 text-center px-2 py-1.5 rounded-full text-xs font-medium bg-white text-gray-600 hover:bg-gray-50 transition-colors cursor-pointer region-tab"
                        data-region="{{ region }}">
                    {{ region }}
                </button>
            {% endfor %}
        </div>
    </div>
{% endif %}

{# Game cards #}
<div class="space-y-3 {{ showRegionTabs ? 'mt-3' : '' }}" id="game-list">
    {% set currentRegion = null %}
    {% for game in games %}
        {% if showRegionTabs and game.region != currentRegion %}
            {% if currentRegion is not null %}
                <div class="text-center pt-1 pb-2">
                    <button onclick="window.scrollTo({ top: 0, behavior: 'smooth' })" class="text-xs text-gray-400 hover:text-gray-600 cursor-pointer">Back to top</button>
                </div>
            {% endif %}
            {% set currentRegion = game.region %}
            <div id="region-{{ game.region }}" class="pt-1">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">{{ game.region }} Region</h3>
            </div>
        {% endif %}
        <div id="game-card-{{ game.id }}">
            {% include 'game/_card.html.twig' with {
                game: game,
                player1_name: scores.player1_name,
                player2_name: scores.player2_name,
                current_player: current_player,
                picker: pickerMap[game.id] is defined ? pickerMap[game.id] : null
            } %}
        </div>
    {% endfor %}
    {% if showRegionTabs and currentRegion is not null %}
        <div class="text-center pt-1 pb-2">
            <button onclick="window.scrollTo({ top: 0, behavior: 'smooth' })" class="text-xs text-gray-400 hover:text-gray-600 cursor-pointer">Back to top</button>
        </div>
    {% endif %}

    {% if games is empty %}
        <p class="text-gray-500 text-center py-8">No games in this round yet.</p>
    {% endif %}
</div>
{% endblock %}
