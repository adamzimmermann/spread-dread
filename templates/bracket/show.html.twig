{% extends 'base.html.twig' %}

{% block title %}{{ bracket.name }} - March Madness{% endblock %}

{% block body %}
<div class="mb-3 flex items-start justify-between">
    <div>
        <h1 class="text-xl font-bold text-gray-800">{{ bracket.name }}</h1>
        <p class="text-sm text-gray-500">{{ bracket.year }}</p>
    </div>
    <a href="{{ path('app_bracket_edit', {id: bracket.id}) }}"
       class="text-sm text-blue-600 hover:underline mt-1">Edit</a>
</div>

{# Sticky score card #}
<div class="sticky top-0 z-10 bg-blue-700 text-white rounded-lg px-4 py-3 mb-4 shadow-lg" id="score-card">
    <div class="flex items-center justify-between">
        <div class="text-center flex-1">
            <div class="text-xs uppercase tracking-wide opacity-80">{{ scores.player1_name }}</div>
            <div class="text-2xl font-bold" id="score-p1">{{ scores.player1 }}</div>
        </div>
        <div class="text-lg font-light opacity-60 px-2">vs</div>
        <div class="text-center flex-1">
            <div class="text-xs uppercase tracking-wide opacity-80">{{ scores.player2_name }}</div>
            <div class="text-2xl font-bold" id="score-p2">{{ scores.player2 }}</div>
        </div>
    </div>
</div>

{# Round tabs #}
<div class="flex gap-2 overflow-x-auto pb-2 mb-3 -mx-1 px-1" id="round-tabs">
    {% for roundNum, roundName in availableRounds %}
        <a href="{{ path('app_bracket_show', {id: bracket.id, round: roundNum}) }}"
           class="whitespace-nowrap px-3 py-1.5 rounded-full text-sm font-medium transition-colors
                  {{ currentRound == roundNum ? 'bg-blue-700 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' }}">
            {{ roundName }}
        </a>
    {% endfor %}
</div>

{# Action buttons #}
<div class="flex gap-2 mb-4">
    <button onclick="pullSpreads({{ bracket.id }}, {{ currentRound }})"
            class="flex-1 bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded text-sm font-medium hover:bg-gray-50"
            id="btn-spreads">
        Pull Spreads
    </button>
    <button onclick="updateScores({{ bracket.id }}, {{ currentRound }})"
            class="flex-1 bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded text-sm font-medium hover:bg-gray-50"
            id="btn-scores">
        Update Scores
    </button>
    <a href="{{ path('app_bracket_teams', {id: bracket.id}) }}"
       class="bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded text-sm font-medium hover:bg-gray-50">
        Teams
    </a>
</div>

{# Game cards #}
<div class="space-y-3" id="game-list">
    {% for game in games %}
        <div id="game-card-{{ game.id }}">
            {% include 'game/_card.html.twig' with {
                game: game,
                player1_name: scores.player1_name,
                player2_name: scores.player2_name
            } %}
        </div>
    {% endfor %}

    {% if games is empty %}
        <p class="text-gray-500 text-center py-8">No games in this round yet.</p>
    {% endif %}
</div>
{% endblock %}
