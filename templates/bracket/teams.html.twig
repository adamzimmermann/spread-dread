{% extends 'base.html.twig' %}

{% block title %}Enter Teams - {{ bracket.name }}{% endblock %}

{% block body %}
<h1 class="text-xl font-bold text-gray-800 mb-1">Enter Teams</h1>
<p class="text-sm text-gray-500 mb-4">{{ bracket.name }} ({{ bracket.year }})</p>

<form method="post" class="space-y-6">
    {% for region in regions %}
        <div class="bg-white rounded-lg shadow p-4">
            <h2 class="font-bold text-gray-700 mb-3">{{ region }}</h2>
            <div class="space-y-2">
                {% for seed in 1..16 %}
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400 w-5 text-right">{{ seed }}</span>
                        <input type="text"
                               name="team_{{ region }}_{{ seed }}"
                               value="{{ existingTeams[region][seed] ?? '' }}"
                               placeholder="{{ seed }} seed"
                               class="flex-1 border border-gray-200 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}

    <button type="submit"
            class="w-full bg-blue-700 text-white py-2 rounded font-medium hover:bg-blue-800">
        Save Teams
    </button>
</form>

<a href="{{ path('app_bracket_show', {id: bracket.id}) }}" class="block text-center text-sm text-blue-600 mt-4 hover:underline">Skip for now</a>
{% endblock %}
