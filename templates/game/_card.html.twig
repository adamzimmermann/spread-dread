{# Game card partial - receives: game, player1_name, player2_name, current_player, warning (optional) #}
{% set _current_player = current_player is defined ? current_player : null %}
{% set _opponent_name = _current_player == 1 ? player2_name : (_current_player == 2 ? player1_name : null) %}
<div class="bg-white rounded-lg shadow p-4 {{ game.isComplete ? 'border-l-4 border-green-500' : '' }} {{ warning is defined and warning ? 'border-l-4 border-yellow-400' : '' }}">
    {# Warning banner #}
    {% set _warning = warning is defined and warning ? warning : null %}
    {% if not _warning and game.team1 and game.team2 and not game.externalGameId %}
        {% set _warning = 'No API match — spread and scores must be entered manually' %}
    {% endif %}
    {% if _warning %}
        <div class="flex items-center gap-1.5 bg-yellow-50 text-yellow-700 text-xs px-2.5 py-1.5 rounded mb-2 -mt-1">
            <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.168 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
            {{ _warning }}
        </div>
    {% endif %}

    {# Header: region + round #}
    <div class="flex items-center justify-between mb-2">
        <span class="text-xs text-gray-400 uppercase tracking-wide">
            {{ game.region ?? 'National' }} &middot; {{ game.roundName }}
        </span>
        {% if game.isComplete %}
            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">Final</span>
        {% endif %}
    </div>

    {# Teams #}
    <div class="space-y-2 mb-3">
        {# Team 1 #}
        <div class="flex items-center justify-between {{ game.winner and game.winner == game.team1 ? 'font-bold' : '' }}">
            <div class="flex items-center gap-2 flex-1 min-w-0">
                {% if game.team1 %}
                    <span class="text-xs text-gray-400 w-5 text-right shrink-0">{{ game.team1.seed }}</span>
                    <span class="truncate">{{ game.team1.name }}</span>
                {% else %}
                    <span class="text-gray-300 italic">TBD</span>
                {% endif %}
            </div>
            {% if game.team1Score is not null %}
                <span class="text-lg font-mono ml-2">{{ game.team1Score }}</span>
            {% endif %}
        </div>

        {# Team 2 #}
        <div class="flex items-center justify-between {{ game.winner and game.winner == game.team2 ? 'font-bold' : '' }}">
            <div class="flex items-center gap-2 flex-1 min-w-0">
                {% if game.team2 %}
                    <span class="text-xs text-gray-400 w-5 text-right shrink-0">{{ game.team2.seed }}</span>
                    <span class="truncate">{{ game.team2.name }}</span>
                {% else %}
                    <span class="text-gray-300 italic">TBD</span>
                {% endif %}
            </div>
            {% if game.team2Score is not null %}
                <span class="text-lg font-mono ml-2">{{ game.team2Score }}</span>
            {% endif %}
        </div>
    </div>

    {# Spread + ATS result #}
    {% if game.spread is not null and game.spreadTeam is not null %}
        {% set absSpread = game.spread < 0 ? game.spread * -1 : game.spread %}
        <div class="text-xs text-gray-500 mb-2">
            Spread: {{ game.spreadTeam.name }} -{{ absSpread }}
            {% if game.isComplete %}
                {% set margin = game.team1Score - game.team2Score %}
                {% if game.spreadTeam == game.team1 %}
                    {% set coveredMargin = margin - absSpread %}
                {% else %}
                    {% set coveredMargin = (margin * -1) - absSpread %}
                {% endif %}
                {% if coveredMargin > 0 %}
                    <span class="text-green-600 font-medium">&middot; {{ game.spreadTeam.name }} covered</span>
                {% elseif coveredMargin < 0 %}
                    {% set underdogTeam = game.spreadTeam == game.team1 ? game.team2 : game.team1 %}
                    <span class="text-green-600 font-medium">&middot; {{ underdogTeam.name }} covered</span>
                {% else %}
                    <span class="text-yellow-600 font-medium">&middot; Push</span>
                {% endif %}
            {% endif %}
        </div>
    {% elseif game.team1 and game.team2 %}
        <div class="mb-2">
            <details class="text-xs" {{ game.isComplete ? 'open' : '' }}>
                <summary class="text-gray-400 cursor-pointer hover:text-gray-600">{{ game.isComplete ? 'Set spread (needed to evaluate picks)' : 'Set spread manually' }}</summary>
                <div class="mt-1 flex gap-1 items-center">
                    <select class="border border-gray-200 rounded px-1 py-0.5 text-xs" id="spread-team-{{ game.id }}">
                        <option value="{{ game.team1.id }}">{{ game.team1.name }}</option>
                        <option value="{{ game.team2.id }}">{{ game.team2.name }}</option>
                    </select>
                    <span class="text-gray-400">-</span>
                    <input type="number" step="0.5" placeholder="5.5"
                           class="border border-gray-200 rounded px-1 py-0.5 text-xs w-14"
                           id="spread-val-{{ game.id }}">
                    <button onclick="setSpread({{ game.id }})"
                            class="bg-gray-200 text-gray-600 px-2 py-0.5 rounded text-xs hover:bg-gray-300">Set</button>
                </div>
            </details>
        </div>
    {% endif %}


    {# Picks — tap a team to pick it, opponent auto-gets the other #}
    {% if game.team1 and game.team2 and _current_player %}
        {% set myPick = game.getPickForPlayer(_current_player) %}
        {% set opponentPlayer = _current_player == 1 ? 2 : 1 %}
        {% set opponentPick = game.getPickForPlayer(opponentPlayer) %}
        <div class="border-t border-gray-100 pt-2">
            <div class="text-xs text-gray-400 mb-1">Your pick ({{ _opponent_name }} gets the other):</div>
            <div class="flex gap-1">
                <button onclick="assignPick({{ game.id }}, {{ game.team1.id }})"
                        class="flex-1 text-xs px-2 py-1.5 rounded border transition-colors
                               {{ game.isComplete ? 'opacity-60 cursor-not-allowed' : 'cursor-pointer' }}
                               {{ myPick and myPick.team == game.team1
                                  ? (myPick.isWinner is same as(true) ? 'bg-green-600 text-white border-green-600'
                                     : (myPick.isWinner is same as(false) ? 'bg-red-100 text-red-700 border-red-300'
                                        : 'bg-blue-600 text-white border-blue-600'))
                                  : 'border-gray-200 text-gray-600 hover:border-blue-400' }}"
                        {{ game.isComplete ? 'disabled' : '' }}>
                    {{ game.team1.name }}
                    {% if myPick and myPick.team == game.team1 %}
                        <span class="opacity-75">(You)</span>
                    {% elseif opponentPick and opponentPick.team == game.team1 %}
                        <span class="opacity-75">({{ _opponent_name }})</span>
                    {% endif %}
                </button>
                <button onclick="assignPick({{ game.id }}, {{ game.team2.id }})"
                        class="flex-1 text-xs px-2 py-1.5 rounded border transition-colors
                               {{ game.isComplete ? 'opacity-60 cursor-not-allowed' : 'cursor-pointer' }}
                               {{ myPick and myPick.team == game.team2
                                  ? (myPick.isWinner is same as(true) ? 'bg-green-600 text-white border-green-600'
                                     : (myPick.isWinner is same as(false) ? 'bg-red-100 text-red-700 border-red-300'
                                        : 'bg-blue-600 text-white border-blue-600'))
                                  : 'border-gray-200 text-gray-600 hover:border-blue-400' }}"
                        {{ game.isComplete ? 'disabled' : '' }}>
                    {{ game.team2.name }}
                    {% if myPick and myPick.team == game.team2 %}
                        <span class="opacity-75">(You)</span>
                    {% elseif opponentPick and opponentPick.team == game.team2 %}
                        <span class="opacity-75">({{ _opponent_name }})</span>
                    {% endif %}
                </button>
            </div>
        </div>
    {% endif %}

    {# Next game context #}
    {% if game.nextGame %}
        <div class="text-xs text-gray-400 mt-2">
            Winner plays in {{ game.nextGame.roundName }}
            {% if game.nextGame.region %} ({{ game.nextGame.region }}){% endif %}
        </div>
    {% endif %}
</div>
